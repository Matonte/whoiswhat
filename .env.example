# Copy to .env in the project root and adjust.

# PostgreSQL example (create database whoiswhat first):
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/whoiswhat

# SQLite example (path is relative to the process working directory — run from project root):
DATABASE_URL=sqlite:///./whoiswhat.db

# OpenAI — required for /classify and POST /api/v1/classify
OPENAI_API_KEY=sk-...
# Optional (default gpt-4o-mini):
# OPENAI_MODEL=gpt-4o-mini
