# Copy to .env in the project root and adjust.



# --- contact_advisor service (K taxonomy + people-intel; formerly whoiswhat) ----------

# PostgreSQL example (create database contact_advisor first):

# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/contact_advisor



# SQLite example (path is relative to the process working directory — run from project root):

DATABASE_URL=sqlite:///./contact_advisor.db



# --- whoishoss service ------------------------------------------------------

# Separate DB per microservice by default. Falls back to DATABASE_URL if unset.

HOSS_DATABASE_URL=sqlite:///./whoishoss.db



# --- meeting_advisor service ------------------------------------------------

# Separate DB for the advisor. Calls Contact Advisor (K) and WhoIsHoss over HTTP.

ADVISOR_DATABASE_URL=sqlite:///./meeting_advisor.db

CONTACT_ADVISOR_URL=http://127.0.0.1:5000

# Deprecated alias — same as CONTACT_ADVISOR_URL if you still use older tooling:

# WHOISWHAT_URL=http://127.0.0.1:5000

WHOISHOSS_URL=http://127.0.0.1:5002

# Seconds for HTTP POST to sibling /classify (each call runs OpenAI there). Increase if you see read timeouts.

# ADVISOR_SIBLING_HTTP_TIMEOUT=120

# ADVISOR_CACHE_TTL_SECONDS=86400



# --- shared: OpenAI ---------------------------------------------------------

# Required for /classify (contact_advisor), /hoss (whoishoss), /advise (advisor).

OPENAI_API_KEY=sk-...



# Current production family (Apr 2026): gpt-5.4-nano, gpt-5.4-mini, gpt-5.4, gpt-5.4-pro.

# Fleet-wide default (used by all services unless they set their own override).

OPENAI_MODEL=gpt-5.4-mini



# Per-service overrides. Each falls back to OPENAI_MODEL.

# The advisor synthesizes 2 profiles + user context — it benefits from the full model;

# classification jobs are fine on the cheaper -mini.

# CONTACT_ADVISOR_MODEL=gpt-5.4-mini

# Deprecated alias:

# WHOISWHAT_MODEL=gpt-5.4-mini

# Optional: dedicated model for POST /api/v1/people-intel (falls back to CONTACT_ADVISOR_MODEL → WHOISWHAT_MODEL → OPENAI_MODEL).

# CONTACT_ADVISOR_PEOPLE_INTEL_MODEL=gpt-5.4-mini

# WHOISHOSS_MODEL=gpt-5.4-mini

# ADVISOR_MODEL=gpt-5.4

