<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns"><key id="d0" for="node" attr_name="label" attr_type="string" /><key id="d1" for="node" attr_name="node_type" attr_type="string" /><key id="d2" for="node" attr_name="description" attr_type="string" /><key id="d3" for="edge" attr_name="relation" attr_type="string" /><graph edgedefault="directed" id="G"><node id="K0"><data key="d0">normal</data><data key="d1">category</data><data key="d2">Baseline behavior with adequate awareness, fair intent, and reasonable self-control.</data></node><node id="K1"><data key="d0">idiot</data><data key="d1">category</data><data key="d2">Primary failure in awareness or understanding; harm is mostly caused by confusion, ignorance, or poor reasoning.</data></node><node id="K2"><data key="d0">asshole</data><data key="d1">category</data><data key="d2">Primary failure in intent or regard for others; behavior is knowingly selfish, callous, or exploitative.</data></node><node id="K3"><data key="d0">jackass</data><data key="d1">category</data><data key="d2">Primary failure in self-control, recklessness, or ego-driven behavior; disruptive even when not purely malicious.</data></node><node id="K4"><data key="d0">shitbird</data><data key="d1">category</data><data key="d2">Composite of K1 + K3: low awareness plus recklessness; chaotic and disruptive without stable understanding.</data></node><node id="K5"><data key="d0">dipshit</data><data key="d1">category</data><data key="d2">Composite of K1 + K2: poor understanding plus selfish intent; harms others while also reasoning badly.</data></node><node id="K6"><data key="d0">fuckhead</data><data key="d1">category</data><data key="d2">Composite of K2 + K3: selfish intent plus recklessness; knowingly harmful and impulsively damaging.</data></node><node id="D1"><data key="d0">awareness_failure</data><data key="d1">dimension</data><data key="d2">Deficit in understanding, foresight, or competence.</data></node><node id="D2"><data key="d0">intent_failure</data><data key="d1">dimension</data><data key="d2">Deficit in fairness, regard for others, or pro-social intent.</data></node><node id="D3"><data key="d0">control_failure</data><data key="d1">dimension</data><data key="d2">Deficit in self-control, prudence, or ego regulation.</data></node><edge id="e1" source="K1" target="D1"><data key="d3">PRIMARY_FAILURE</data></edge><edge id="e2" source="K2" target="D2"><data key="d3">PRIMARY_FAILURE</data></edge><edge id="e3" source="K3" target="D3"><data key="d3">PRIMARY_FAILURE</data></edge><edge id="e4" source="K4" target="K1"><data key="d3">COMPOSED_OF</data></edge><edge id="e5" source="K4" target="K3"><data key="d3">COMPOSED_OF</data></edge><edge id="e6" source="K5" target="K1"><data key="d3">COMPOSED_OF</data></edge><edge id="e7" source="K5" target="K2"><data key="d3">COMPOSED_OF</data></edge><edge id="e8" source="K6" target="K2"><data key="d3">COMPOSED_OF</data></edge><edge id="e9" source="K6" target="K3"><data key="d3">COMPOSED_OF</data></edge><edge id="e10" source="K0" target="D1"><data key="d3">LOW_FAILURE</data></edge><edge id="e11" source="K0" target="D2"><data key="d3">LOW_FAILURE</data></edge><edge id="e12" source="K0" target="D3"><data key="d3">LOW_FAILURE</data></edge></graph></graphml>